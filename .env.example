APP_NAME=Wsaler
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration
# WARNING: SQLite DOES NOT support proper row-level locking and MUST NOT be used in production
# Use PostgreSQL or MySQL for production environments to ensure data integrity
DB_CONNECTION=sqlite

# Production: PostgreSQL (Recommended)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=wsaler
# DB_USERNAME=wsaler_user
# DB_PASSWORD=

# Alternative: MySQL
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=wsaler
# DB_USERNAME=wsaler_user
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Production: Use Redis for better queue performance and reliability
# QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

# Production: Use Redis for better cache performance
# CACHE_STORE=redis
# CACHE_PREFIX=wsaler_cache

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# File Upload Configuration
MAX_UPLOAD_SIZE=5120
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp
ALLOWED_DOCUMENT_EXTENSIONS=pdf,doc,docx,xls,xlsx

# API Rate Limiting (requests per minute)
THROTTLE_LOGIN_MAX_ATTEMPTS=5
THROTTLE_LOGIN_DECAY_MINUTES=1
THROTTLE_API_MAX_ATTEMPTS=60
THROTTLE_API_DECAY_MINUTES=1

# Security
FORCE_HTTPS=false
# Set to true in production to enforce HTTPS

# Queue Configuration
# Specify which queues to process (comma-separated)
QUEUE_NAMES=default,emails,notifications

# Monitoring & Logging (Production)
# SENTRY_LARAVEL_DSN=
# LOG_LEVEL=warning
# LOG_SLACK_WEBHOOK_URL=
